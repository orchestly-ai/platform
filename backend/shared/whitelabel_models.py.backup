"""
White-Label & Reseller Program Models - P2 Feature #4

Data models for white-labeling, reseller programs, and multi-tenancy.

Enables:
- Custom branding (logo, colors, domain)
- Reseller portal and management
- Revenue sharing and commissions
- Multi-tenant architecture
- Usage-based billing
- Partner onboarding
"""

from sqlalchemy import (
    Column, Integer, String, Text, DateTime, Boolean, JSON, Float, Numeric,
    ForeignKey, Enum as SQLEnum, Index, UniqueConstraint
)
from sqlalchemy.orm import relationship
from sqlalchemy.sql import func
from pydantic import BaseModel, Field, validator
from typing import Optional, List, Dict, Any
from datetime import datetime
from enum import Enum


from backend.database.base import Base


# ============================================================================
# Enums
# ============================================================================

class PartnerTier(str, Enum):
    """Partner tier levels."""
    BASIC = "basic"  # 10% commission
    SILVER = "silver"  # 15% commission
    GOLD = "gold"  # 20% commission
    PLATINUM = "platinum"  # 25% commission
    ENTERPRISE = "enterprise"  # Custom terms


class PartnerStatus(str, Enum):
    """Partner account status."""
    PENDING = "pending"  # Application pending
    ACTIVE = "active"  # Active partner
    SUSPENDED = "suspended"  # Temporarily suspended
    TERMINATED = "terminated"  # Partnership terminated


class BrandingStatus(str, Enum):
    """Custom branding status."""
    DRAFT = "draft"  # Being configured
    PENDING_REVIEW = "pending_review"  # Awaiting approval
    APPROVED = "approved"  # Live
    REJECTED = "rejected"  # Rejected


class CommissionStatus(str, Enum):
    """Commission payment status."""
    PENDING = "pending"
    APPROVED = "approved"
    PAID = "paid"
    DISPUTED = "disputed"


class BillingCycle(str, Enum):
    """Billing cycle."""
    MONTHLY = "monthly"
    QUARTERLY = "quarterly"
    ANNUAL = "annual"


# ============================================================================
# Database Models
# ============================================================================

class Partner(Base):
    """
    Reseller partner account.

    Partners can resell the platform under their own brand.
    """
    __tablename__ = "partners"

    id = Column(Integer, primary_key=True, index=True)

    # Partner info
    company_name = Column(String(255), nullable=False, index=True)
    partner_code = Column(String(50), unique=True, nullable=False, index=True)  # Unique partner identifier

    # Contact
    primary_contact_name = Column(String(255), nullable=False)
    primary_contact_email = Column(String(255), nullable=False, index=True)
    primary_contact_phone = Column(String(50), nullable=True)

    # Address
    address_line1 = Column(String(255), nullable=True)
    address_line2 = Column(String(255), nullable=True)
    city = Column(String(100), nullable=True)
    state = Column(String(100), nullable=True)
    postal_code = Column(String(20), nullable=True)
    country = Column(String(100), nullable=True)

    # Business details
    tax_id = Column(String(100), nullable=True)  # VAT/EIN
    business_type = Column(String(100), nullable=True)  # LLC, Corp, etc.
    website = Column(String(500), nullable=True)

    # Partnership
    tier = Column(SQLEnum(PartnerTier), default=PartnerTier.BASIC, nullable=False, index=True)
    status = Column(SQLEnum(PartnerStatus), default=PartnerStatus.PENDING, nullable=False, index=True)

    # Commission rates (percentage)
    commission_rate = Column(Float, default=10.0, nullable=False)  # Percentage
    custom_commission_rules = Column(JSON, default=dict)  # Custom rules by product/tier

    # Billing
    billing_email = Column(String(255), nullable=True)
    payment_method = Column(String(50), nullable=True)  # stripe, wire, check
    payment_details = Column(JSON, default=dict)  # Encrypted payment info

    # Referral tracking
    referral_code = Column(String(50), unique=True, nullable=True, index=True)

    # Metrics
    total_customers = Column(Integer, default=0)
    total_revenue_usd = Column(Numeric(precision=20, scale=2), default=0.0)
    total_commission_usd = Column(Numeric(precision=20, scale=2), default=0.0)

    # Terms
    contract_start_date = Column(DateTime, nullable=True)
    contract_end_date = Column(DateTime, nullable=True)
    terms_accepted_at = Column(DateTime, nullable=True)

    # Audit
    created_at = Column(DateTime, server_default=func.now(), nullable=False, index=True)
    updated_at = Column(DateTime, server_default=func.now(), onupdate=func.now())
    activated_at = Column(DateTime, nullable=True)
    suspended_at = Column(DateTime, nullable=True)

    # Relationships
    brandings = relationship("WhiteLabelBranding", back_populates="partner", cascade="all, delete-orphan")
    customers = relationship("PartnerCustomer", back_populates="partner", cascade="all, delete-orphan")
    commissions = relationship("Commission", back_populates="partner", cascade="all, delete-orphan")

    __table_args__ = (
        Index("ix_partner_tier_status", "tier", "status"),
        Index("ix_partner_created", "created_at"),
    )


class WhiteLabelBranding(Base):
    """
    Custom branding configuration.

    Allows partners to customize the platform appearance.
    """
    __tablename__ = "whitelabel_branding"

    id = Column(Integer, primary_key=True, index=True)

    # Partner
    partner_id = Column(Integer, ForeignKey("partners.id", ondelete="CASCADE"), nullable=False, index=True)

    # Domain
    custom_domain = Column(String(255), unique=True, nullable=True, index=True)  # app.partner.com
    domain_verified = Column(Boolean, default=False, nullable=False)
    ssl_enabled = Column(Boolean, default=False, nullable=False)

    # Visual branding
    company_name = Column(String(255), nullable=False)  # Display name
    logo_url = Column(String(500), nullable=True)
    favicon_url = Column(String(500), nullable=True)

    # Color scheme
    primary_color = Column(String(7), nullable=True)  # Hex color #RRGGBB
    secondary_color = Column(String(7), nullable=True)
    accent_color = Column(String(7), nullable=True)
    background_color = Column(String(7), nullable=True)
    text_color = Column(String(7), nullable=True)

    # Custom CSS
    custom_css = Column(Text, nullable=True)

    # Email branding
    email_from_name = Column(String(255), nullable=True)
    email_from_address = Column(String(255), nullable=True)
    email_logo_url = Column(String(500), nullable=True)
    email_footer = Column(Text, nullable=True)

    # Support
    support_email = Column(String(255), nullable=True)
    support_phone = Column(String(50), nullable=True)
    support_url = Column(String(500), nullable=True)

    # Legal
    privacy_policy_url = Column(String(500), nullable=True)
    terms_of_service_url = Column(String(500), nullable=True)

    # Social media
    social_links = Column(JSON, default=dict)  # {twitter, linkedin, facebook, etc.}

    # Status
    status = Column(SQLEnum(BrandingStatus), default=BrandingStatus.DRAFT, nullable=False, index=True)
    is_active = Column(Boolean, default=False, nullable=False, index=True)

    # Metadata
    extra_metadata = Column(JSON, default=dict)

    # Audit
    created_at = Column(DateTime, server_default=func.now(), nullable=False)
    updated_at = Column(DateTime, server_default=func.now(), onupdate=func.now())
    approved_at = Column(DateTime, nullable=True)
    approved_by = Column(String(255), nullable=True)

    # Relationships
    partner = relationship("Partner", back_populates="brandings")

    __table_args__ = (
        Index("ix_branding_partner_status", "partner_id", "status"),
    )


class PartnerCustomer(Base):
    """
    Customer acquired through partner.

    Tracks customers brought in by resellers.
    """
    __tablename__ = "partner_customers"

    id = Column(Integer, primary_key=True, index=True)

    # Partner
    partner_id = Column(Integer, ForeignKey("partners.id", ondelete="CASCADE"), nullable=False, index=True)

    # Customer
    customer_email = Column(String(255), nullable=False, index=True)
    customer_name = Column(String(255), nullable=True)
    organization_id = Column(Integer, nullable=True, index=True)  # Link to actual organization

    # Subscription
    plan_name = Column(String(100), nullable=True)
    billing_cycle = Column(SQLEnum(BillingCycle), nullable=True)
    mrr_usd = Column(Numeric(precision=20, scale=2), default=0.0)  # Monthly recurring revenue

    # Status
    is_active = Column(Boolean, default=True, nullable=False, index=True)

    # Tracking
    referral_source = Column(String(255), nullable=True)
    utm_campaign = Column(String(255), nullable=True)
    utm_source = Column(String(255), nullable=True)
    utm_medium = Column(String(255), nullable=True)

    # Audit
    created_at = Column(DateTime, server_default=func.now(), nullable=False, index=True)
    activated_at = Column(DateTime, nullable=True)
    churned_at = Column(DateTime, nullable=True)

    # Relationships
    partner = relationship("Partner", back_populates="customers")

    __table_args__ = (
        Index("ix_partner_customer_active", "partner_id", "is_active"),
        Index("ix_partner_customer_email", "partner_id", "customer_email"),
    )


class Commission(Base):
    """
    Partner commission record.

    Tracks commissions earned by partners.
    """
    __tablename__ = "commissions"

    id = Column(Integer, primary_key=True, index=True)

    # Partner
    partner_id = Column(Integer, ForeignKey("partners.id", ondelete="CASCADE"), nullable=False, index=True)

    # Period
    period_start = Column(DateTime, nullable=False, index=True)
    period_end = Column(DateTime, nullable=False, index=True)

    # Amounts
    gross_revenue_usd = Column(Numeric(precision=20, scale=2), nullable=False)  # Total revenue
    commission_rate = Column(Float, nullable=False)  # Percentage applied
    commission_amount_usd = Column(Numeric(precision=20, scale=2), nullable=False)  # Commission earned

    # Breakdown
    customer_count = Column(Integer, default=0)
    transaction_count = Column(Integer, default=0)
    details = Column(JSON, default=dict)  # Detailed breakdown

    # Payment
    status = Column(SQLEnum(CommissionStatus), default=CommissionStatus.PENDING, nullable=False, index=True)
    payment_date = Column(DateTime, nullable=True)
    payment_reference = Column(String(255), nullable=True)
    payment_method = Column(String(50), nullable=True)

    # Notes
    notes = Column(Text, nullable=True)

    # Audit
    created_at = Column(DateTime, server_default=func.now(), nullable=False, index=True)
    updated_at = Column(DateTime, server_default=func.now(), onupdate=func.now())

    # Relationships
    partner = relationship("Partner", back_populates="commissions")

    __table_args__ = (
        Index("ix_commission_partner_period", "partner_id", "period_start", "period_end"),
        Index("ix_commission_status_date", "status", "payment_date"),
    )


class PartnerApiKey(Base):
    """
    API key for partner integration.

    Allows partners to integrate programmatically.
    """
    __tablename__ = "partner_api_keys"

    id = Column(Integer, primary_key=True, index=True)

    # Partner
    partner_id = Column(Integer, ForeignKey("partners.id", ondelete="CASCADE"), nullable=False, index=True)

    # Key
    key_name = Column(String(255), nullable=False)
    key_hash = Column(String(255), unique=True, nullable=False, index=True)  # Hashed key
    key_prefix = Column(String(20), nullable=False)  # First few chars for identification

    # Permissions
    scopes = Column(JSON, default=list)  # List of allowed scopes

    # Rate limiting
    rate_limit_per_minute = Column(Integer, default=60)
    rate_limit_per_hour = Column(Integer, default=1000)

    # Status
    is_active = Column(Boolean, default=True, nullable=False, index=True)

    # Usage tracking
    last_used_at = Column(DateTime, nullable=True)
    usage_count = Column(Integer, default=0)

    # Audit
    created_at = Column(DateTime, server_default=func.now(), nullable=False, index=True)
    expires_at = Column(DateTime, nullable=True, index=True)
    revoked_at = Column(DateTime, nullable=True)

    __table_args__ = (
        Index("ix_api_key_partner_active", "partner_id", "is_active"),
    )


class PartnerResource(Base):
    """
    Partner resources and assets.

    Marketing materials, documentation, etc.
    """
    __tablename__ = "partner_resources"

    id = Column(Integer, primary_key=True, index=True)

    # Resource info
    title = Column(String(255), nullable=False, index=True)
    description = Column(Text, nullable=True)
    resource_type = Column(String(50), nullable=False, index=True)  # marketing, documentation, training

    # File
    file_url = Column(String(500), nullable=True)
    file_size_bytes = Column(Integer, nullable=True)
    file_type = Column(String(50), nullable=True)  # pdf, video, image, etc.

    # Access control
    visibility = Column(String(50), default="all_partners", nullable=False)  # all_partners, tier_specific
    required_tier = Column(SQLEnum(PartnerTier), nullable=True)

    # Metadata
    tags = Column(JSON, default=list)
    category = Column(String(100), nullable=True)

    # Stats
    download_count = Column(Integer, default=0)
    view_count = Column(Integer, default=0)

    # Audit
    created_at = Column(DateTime, server_default=func.now(), nullable=False, index=True)
    updated_at = Column(DateTime, server_default=func.now(), onupdate=func.now())
    created_by = Column(String(255), nullable=False)

    __table_args__ = (
        Index("ix_resource_type_tier", "resource_type", "required_tier"),
    )


# ============================================================================
# Pydantic Models (API Schemas)
# ============================================================================

class PartnerCreate(BaseModel):
    """Create partner account."""
    company_name: str = Field(..., max_length=255)
    primary_contact_name: str = Field(..., max_length=255)
    primary_contact_email: str = Field(..., max_length=255)
    primary_contact_phone: Optional[str] = Field(None, max_length=50)
    website: Optional[str] = None
    business_type: Optional[str] = None
    address_line1: Optional[str] = None
    city: Optional[str] = None
    state: Optional[str] = None
    postal_code: Optional[str] = None
    country: Optional[str] = None


class PartnerUpdate(BaseModel):
    """Update partner account."""
    company_name: Optional[str] = Field(None, max_length=255)
    primary_contact_name: Optional[str] = Field(None, max_length=255)
    primary_contact_email: Optional[str] = Field(None, max_length=255)
    primary_contact_phone: Optional[str] = Field(None, max_length=50)
    website: Optional[str] = None
    tier: Optional[PartnerTier] = None
    status: Optional[PartnerStatus] = None
    commission_rate: Optional[float] = Field(None, ge=0, le=100)


class PartnerResponse(BaseModel):
    """Partner account response."""
    id: int
    company_name: str
    partner_code: str
    primary_contact_name: str
    primary_contact_email: str
    tier: PartnerTier
    status: PartnerStatus
    commission_rate: float
    total_customers: int
    total_revenue_usd: float
    total_commission_usd: float
    created_at: datetime
    activated_at: Optional[datetime]

    class Config:
        from_attributes = True


class BrandingCreate(BaseModel):
    """Create white-label branding."""
    custom_domain: Optional[str] = None
    company_name: str = Field(..., max_length=255)
    logo_url: Optional[str] = None
    favicon_url: Optional[str] = None
    primary_color: Optional[str] = Field(None, pattern=r'^#[0-9A-Fa-f]{6}$')
    secondary_color: Optional[str] = Field(None, pattern=r'^#[0-9A-Fa-f]{6}$')
    accent_color: Optional[str] = Field(None, pattern=r'^#[0-9A-Fa-f]{6}$')
    support_email: Optional[str] = None
    support_url: Optional[str] = None
    privacy_policy_url: Optional[str] = None
    terms_of_service_url: Optional[str] = None


class BrandingUpdate(BaseModel):
    """Update branding."""
    company_name: Optional[str] = Field(None, max_length=255)
    logo_url: Optional[str] = None
    favicon_url: Optional[str] = None
    primary_color: Optional[str] = Field(None, pattern=r'^#[0-9A-Fa-f]{6}$')
    secondary_color: Optional[str] = Field(None, pattern=r'^#[0-9A-Fa-f]{6}$')
    accent_color: Optional[str] = Field(None, pattern=r'^#[0-9A-Fa-f]{6}$')
    support_email: Optional[str] = None
    custom_css: Optional[str] = None


class BrandingResponse(BaseModel):
    """Branding response."""
    id: int
    partner_id: int
    custom_domain: Optional[str]
    domain_verified: bool
    company_name: str
    logo_url: Optional[str]
    primary_color: Optional[str]
    secondary_color: Optional[str]
    status: BrandingStatus
    is_active: bool
    created_at: datetime

    class Config:
        from_attributes = True


class CustomerCreate(BaseModel):
    """Add partner customer."""
    customer_email: str = Field(..., max_length=255)
    customer_name: Optional[str] = Field(None, max_length=255)
    plan_name: Optional[str] = None
    billing_cycle: Optional[BillingCycle] = None
    mrr_usd: float = Field(0.0, ge=0)
    referral_source: Optional[str] = None


class CustomerResponse(BaseModel):
    """Customer response."""
    id: int
    partner_id: int
    customer_email: str
    customer_name: Optional[str]
    plan_name: Optional[str]
    mrr_usd: float
    is_active: bool
    created_at: datetime
    activated_at: Optional[datetime]

    class Config:
        from_attributes = True


class CommissionResponse(BaseModel):
    """Commission response."""
    id: int
    partner_id: int
    period_start: datetime
    period_end: datetime
    gross_revenue_usd: float
    commission_rate: float
    commission_amount_usd: float
    customer_count: int
    status: CommissionStatus
    payment_date: Optional[datetime]
    created_at: datetime

    class Config:
        from_attributes = True


class PartnerStats(BaseModel):
    """Partner statistics."""
    partner_id: int
    total_customers: int
    active_customers: int
    churned_customers: int
    total_revenue_usd: float
    total_commission_usd: float
    pending_commission_usd: float
    avg_customer_value_usd: float
    customer_retention_rate: float


class ApiKeyCreate(BaseModel):
    """Create API key."""
    key_name: str = Field(..., max_length=255)
    scopes: List[str] = Field(default_factory=list)
    expires_at: Optional[datetime] = None


class ApiKeyResponse(BaseModel):
    """API key response."""
    id: int
    partner_id: int
    key_name: str
    key_prefix: str
    scopes: List[str]
    is_active: bool
    created_at: datetime
    expires_at: Optional[datetime]
    last_used_at: Optional[datetime]

    class Config:
        from_attributes = True
