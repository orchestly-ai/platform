"""
LLM Pricing Configuration & Cost Calculation

Token-based cost calculation with configurable pricing.
Supports organization-specific negotiated rates and public list pricing.
"""

from sqlalchemy import Column, String, Text, Boolean, DECIMAL, TIMESTAMP, ForeignKey
from sqlalchemy.sql import func
from backend.database.session import Base
from datetime import datetime
from typing import Optional, Dict
from decimal import Decimal
from pydantic import BaseModel, Field


