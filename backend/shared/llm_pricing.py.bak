# ============================================================================
# Organization Pricing Configuration Model
# ============================================================================

class OrganizationPricingConfig(Base):
    """
    Organization-specific LLM pricing configuration.
    Allows enterprises to configure their negotiated pricing rates.
    """
    __tablename__ = "organization_pricing_config"

    config_id = Column(String(255), primary_key=True)
    organization_id = Column(String(255), ForeignKey("organizations.organization_id"), nullable=False, index=True)
    provider = Column(String(50), nullable=False, index=True)
    model_name = Column(String(100), nullable=False, index=True)
    input_cost_per_million = Column(DECIMAL(10, 4), nullable=False)
    output_cost_per_million = Column(DECIMAL(10, 4), nullable=False)
    notes = Column(Text)
    effective_date = Column(TIMESTAMP, nullable=False)
    expiry_date = Column(TIMESTAMP)
    created_by = Column(String(255), ForeignKey("users.user_id"), nullable=False)
    created_at = Column(TIMESTAMP, server_default=func.now(), nullable=False)
    updated_at = Column(TIMESTAMP, server_default=func.now(), onupdate=func.now())
    is_active = Column(Boolean, default=True)


# ============================================================================
# Pydantic Models
# ============================================================================

class CostEstimate(BaseModel):
    """Cost estimate with disclaimer"""
    estimated_cost_usd: float
    input_tokens: int
    output_tokens: int
    model_used: str
    provider: str
    pricing_source: str
    input_rate_per_million: float
    output_rate_per_million: float
    disclaimer: str = Field(
        default="Cost estimate based on token usage and pricing rates. "
                "Actual costs may vary based on your negotiated rates with LLM providers."
    )


def calculate_cost_estimate(
    input_tokens: int,
    output_tokens: int,
    model_name: str,
    provider: str,
    custom_pricing: Optional[Dict[str, float]] = None
) -> CostEstimate:
    """Calculate cost estimate for token usage"""
    if custom_pricing:
        input_rate = Decimal(str(custom_pricing["input_per_million"]))
        output_rate = Decimal(str(custom_pricing["output_per_million"]))
        pricing_source = "organization_config"
    else:
        if provider not in PUBLIC_LIST_PRICING:
            raise ValueError(f"Unknown provider: {provider}")
        if model_name not in PUBLIC_LIST_PRICING[provider]:
            raise ValueError(f"Unknown model '{model_name}' for provider '{provider}'")
        
        pricing = PUBLIC_LIST_PRICING[provider][model_name]
        input_rate = Decimal(str(pricing["input_per_million"]))
        output_rate = Decimal(str(pricing["output_per_million"]))
        pricing_source = "public_list_pricing"

    input_cost = (Decimal(input_tokens) / Decimal(1_000_000)) * input_rate
    output_cost = (Decimal(output_tokens) / Decimal(1_000_000)) * output_rate
    total_cost = input_cost + output_cost

    return CostEstimate(
        estimated_cost_usd=float(total_cost),
        input_tokens=input_tokens,
        output_tokens=output_tokens,
        model_used=model_name,
        provider=provider,
        pricing_source=pricing_source,
        input_rate_per_million=float(input_rate),
        output_rate_per_million=float(output_rate)
    )


def get_available_models(provider: Optional[str] = None) -> Dict[str, list]:
    """Get list of available models in public pricing"""
    if provider:
        if provider not in PUBLIC_LIST_PRICING:
            return {}
        return {provider: list(PUBLIC_LIST_PRICING[provider].keys())}
    
    return {
        provider: list(models.keys())
        for provider, models in PUBLIC_LIST_PRICING.items()
    }


def get_model_pricing(provider: str, model_name: str) -> Dict[str, float]:
    """Get pricing for specific model"""
    if provider not in PUBLIC_LIST_PRICING:
        raise ValueError(f"Unknown provider: {provider}")
    if model_name not in PUBLIC_LIST_PRICING[provider]:
        raise ValueError(f"Unknown model '{model_name}' for provider '{provider}'")
    return PUBLIC_LIST_PRICING[provider][model_name]
