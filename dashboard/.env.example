# Orchestly Dashboard Environment Configuration
# Copy this file to .env.local and fill in your values

# Backend API URL (defaults to localhost:8000 for development)
VITE_API_URL=http://localhost:8000

# API Key for authentication
# In development, this defaults to 'debug' if not set
# In production, this MUST be set to a valid API key
VITE_API_KEY=

# Enable debug mode (automatically enabled in development)
# Set to 'true' to enable verbose logging in production
VITE_DEBUG=false
