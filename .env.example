# ============================================================================
# Agent Orchestration Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Application
ENVIRONMENT=development
DEBUG=true

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_orchestrator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ============================================================================
# Redis
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# LLM Provider API Keys
# ============================================================================

# Groq (Fast inference)
GROQ_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Google (Gemini)
GOOGLE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# ============================================================================
# Cost Limits (USD)
# ============================================================================
DEFAULT_AGENT_DAILY_COST_LIMIT=100.0
DEFAULT_AGENT_MONTHLY_COST_LIMIT=3000.0
SYSTEM_DAILY_COST_LIMIT=10000.0
SYSTEM_MONTHLY_COST_LIMIT=300000.0

# ============================================================================
# Task Configuration
# ============================================================================
DEFAULT_TASK_TIMEOUT_SECONDS=300
MAX_TASK_TIMEOUT_SECONDS=3600
DEFAULT_MAX_RETRIES=3
MAX_CONCURRENT_TASKS_PER_AGENT=5

# ============================================================================
# Authentication & Security
# ============================================================================
API_KEY_HEADER=X-API-Key
API_KEY_LENGTH=32
# REQUIRED: Set a strong secret (min 32 chars). Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# Observability
# ============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=5000

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_EXTENDED_ROUTERS=true
ENABLE_VISUAL_WORKFLOW_DESIGNER=false
ENABLE_ML_ROUTING=false
ENABLE_CONFLICT_DETECTION=true
